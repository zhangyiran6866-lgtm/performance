# 当前环境标识（由于被 Vite 加载即代表本地，可作为全局提示）
# 本地开发环境

# 所有的后端请求都会自动拼接这个基础路径前缀
VITE_API_BASE_URL=/admin-api

# 本地联调或反向代理使用的实际后端目标地址
VITE_API_TARGET_URL=http://192.168.10.108:9800

# VITE_API_TARGET_URL=http://121.40.188.195:9800

# 增加TAG，用于指定调试的后端服务所在机器名（如: sujg/mhz/fjh/lzy/jyj 等）。全局请求头会自动带有该 tag 以供网关分发。
VITE_APP_SERVICE_TAG=mhz
